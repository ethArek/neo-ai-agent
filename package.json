{
  "name": "neo-ai-agent",
  "version": "1.0.0",
  "description": "Production-style CLI AI agent for the Neo ecosystem, including Neo N3 and Neo X, built with Node.js and TypeScript.",
  "bin": {
    "neo-ai-agent": "dist/index.js"
  },
  "main": "dist/index.js",
  "license": "MIT",
  "scripts": {
    "clean": "node scripts/clean-dist.cjs",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "dev:api": "tsx watch src/server.ts",
    "cli": "tsx src/index.ts",
    "api": "tsx src/server.ts",
    "start": "node dist/index.js",
    "start:api": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check:ci": "biome format .",
    "check:biome": "biome ci .",
    "test": "jest --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "test:watch": "jest --watch",
    "audit:prod": "npm audit --omit=dev",
    "smoke:start": "node scripts/smoke-start-cli.cjs",
    "smoke:start:api": "node scripts/smoke-start-api.cjs",
    "verify": "npm run check:biome && npm run typecheck && npm run test:coverage && npm run build && npm run smoke:start && npm run smoke:start:api",
    "verify:release": "npm run verify && npm run audit:prod"
  },
  "dependencies": {
    "@cityofzion/neon-api": "^5.8.1",
    "@cityofzion/neon-core": "^5.8.1",
    "@cityofzion/neon-js": "^5.8.1",
    "@google/genai": "^1.46.0",
    "commander": "^14.0.1",
    "dotenv": "^16.6.1",
    "openai": "^6.32.0",
    "pino": "^10.1.0",
    "viem": "^2.48.4",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.3.0",
    "jest": "^30.1.3",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
